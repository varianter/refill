{
  "name": "refil",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "preview": "astro preview",
    "astro": "astro",
    "build": "yarn build-setup && astro build && yarn kill-assets",
    "build-setup": "yarn serve-assets & yarn wait-for-assets",
    "serve-assets": "serve -p 3001 --no-port-switching ./public/assets/img",
    "wait-for-assets": "wait-on -t 5000 http://localhost:3001/hero.png",
    "kill-assets": "kill-port 3001 || true"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/vercel": "^10.0.8",
    "@astrojs/vue": "^6.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vueuse/core": "^14.3.0",
    "astro": "^6.4.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "satori": "^0.26.0",
    "sharp": "^0.35.2",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "kill-port": "^2.0.1",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "serve": "^14.2.6",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  }
}
